[sqlfluff]
dialect = postgres
templater = mako
max_line_length = 80

# LT12: Files must end with a single trailing newline (handled by pre-commit).
# AM04: SELECT * is intentional in example/seed scripts.
# LT14: WHERE on same line is fine for short statements.
# LT09: Multiple select targets on one line is fine for short queries.
exclude_rules = LT12, AM04, LT14, LT09

[sqlfluff:templater:mako]

[sqlfluff:indentation]
indent_unit = space
tab_space_size = 4

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.identifiers]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.functions]
extended_capitalisation_policy = upper

[sqlfluff:rules:capitalisation.literals]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.types]
extended_capitalisation_policy = upper
