set dotenv-load := true

alembic := "uv run --directory .. alembic -c " + justfile_directory() + "/alembic.ini"

# Create the database and apply all migrations
init:
    #!/usr/bin/env bash
    db=$(echo $DATABASE_URL | grep -oP '[^/]+$')
    createdb "$db" 2>/dev/null && echo "Created database: $db" || echo "Database already exists: $db"
    just migrate

# Apply all pending migrations
migrate:
    {{alembic}} upgrade head

# Rollback the last migration
rollback:
    {{alembic}} downgrade -1

# Create a new autogenerated migration: just revision "add users table"
revision msg:
    {{alembic}} revision --autogenerate -m "{{msg}}"

# Show migration history
history:
    {{alembic}} history

# Show current migration state
current:
    {{alembic}} current

# Downgrade to a specific revision: just downgrade abc123
downgrade rev:
    {{alembic}} downgrade {{rev}}

# Open a psql shell using DATABASE_URL
db-shell:
    psql "${DATABASE_URL/+psycopg/}"
